# データベース接続文字列 (ローカル例)
# Renderでは Postgres の Internal Database URL を DATABASE_URL に設定する
DATABASE_URL=postgres://postgres:postgres@localhost:5432/reagent

# サーバーポート
PORT=3000

# セッション署名用シークレット (本番では十分に長いランダム値に変更する)
SESSION_SECRET=change-this-secret

# 実行環境 (development / production)
NODE_ENV=development

# DB接続でSSLを使うか (Renderのマネージドpostgresはtrue推奨。ローカルはfalse)
PGSSL=false

# ローカル起動時に未適用マイグレーションを自動適用する場合は 1 を設定する。
# 本番(Render)では設定しないこと(スキーマ変更は手動マイグレーション運用のため)。
# AUTO_MIGRATE=1

# --- メール送信。プロバイダを選択(未指定は自動判定) ---
# MAIL_PROVIDER=lolipop   # lolipop | resend | none
# 問い合わせの通知先(共通)
# MAIL_TO=info@e-soft.jp
# 差出人の表示名(共有send.phpに fromName として渡す。システムごとに設定)
# MAIL_FROM_NAME=試薬在庫管理システム

# ロリポップ設置の自作PHP(send.php)経由で送信する場合
# LOLIPOP_MAIL_ENDPOINT=https://sendmail.e-soft.jp/send.php
# LOLIPOP_MAIL_TOKEN=（send.php側 mailconfig.php の token と一致させる長いランダム値）

# Resend HTTPS API を使う場合
# RESEND_API_KEY=re_xxx
# MAIL_FROM=onboarding@resend.dev

# --- 公開API(問い合わせ/利用登録)の許可オリジン(カンマ区切り。未設定は全許可) ---
# CONTACT_ORIGINS=https://your-lp.example.com
# SIGNUP_ORIGINS=https://your-lp.example.com

# --- 決済プロバイダ選択 ---
# 画面(全体管理者>決済設定)で切替可能。ここは初期値のフォールバック。
# 選択肢: stripe / mock(疑似) / payjp(未実装) / gmo(未実装)。未指定はstripe設定時stripe、無ければmock。
# PAYMENT_PROVIDER=stripe

# --- 決済(Stripe)。未設定時はローカル疑似決済モードで動作(実課金なし) ---
# 本番で有効化する場合に設定。Price ID は plans.stripe_price_id(DB)に設定する。
# STRIPE_SECRET_KEY=sk_live_xxx / sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# アプリの公開URL(決済後の戻り先・設定リンクの生成に使用。未設定はリクエストから推定)
# APP_BASE_URL=https://reagent-inventory-1wu2.onrender.com

# --- 他決済プロバイダ(アダプタ実装後に使用) ---
# PAYJP_SECRET_KEY=sk_xxx
# GMO_SHOP_ID=xxx
# GMO_SHOP_PASS=xxx
