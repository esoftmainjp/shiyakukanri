# データベース接続文字列 (ローカル例)
# Renderでは Postgres の Internal Database URL を DATABASE_URL に設定する
DATABASE_URL=postgres://postgres:postgres@localhost:5432/reagent

# サーバーポート
PORT=3000

# セッション署名用シークレット (本番では十分に長いランダム値に変更する)
SESSION_SECRET=change-this-secret

# 実行環境 (development / production)
NODE_ENV=development

# DB接続でSSLを使うか (Renderのマネージドpostgresはtrue推奨。ローカルはfalse)
PGSSL=false
